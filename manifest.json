{
  "manifest_version": 3,
  "name": "Smart Leads Tracker",
  "version": "1.0",
  "description": "A lightweight Chrome extension to save and manage website links quickly.",

  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },

  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "assets/icon.png",
      "48": "assets/icon.png",
      "128": "assets/icon.png"
    }
  },

  "permissions": [
    "tabs"
  ]
}